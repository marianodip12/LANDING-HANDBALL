{
  "rewrites": [
    { "source": "/analisis-handball", "destination": "/" },
    { "source": "/estadisticas-handball", "destination": "/" },
    { "source": "/scouting-handball", "destination": "/" },
    { "source": "/software-handball", "destination": "/" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
